# Copy this file to ".env" and paste your real key there.
# ".env" is git-ignored and never enters the chat. Get a key at:
#   https://platform.deepseek.com/  ->  API keys
DEEPSEEK_API_KEY=

# DeepSeek is OpenAI-compatible (base URL + model are config, not code):
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# Slack (Socket Mode) — from the grantscribe app settings:
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# CareerOneStop (scholarships) — free token from careeronestop.org/Developers/WebAPI/registration.aspx
CAREERONESTOP_USERID=
CAREERONESTOP_TOKEN=
